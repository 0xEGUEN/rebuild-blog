---
interface Props {
  title: string;
  description: string;
  category: string;
  author: string;
  date: string;
  readTime?: string;
  href: string;
  image?: string;
}

const { title, description, category, author, date, readTime, href, image } = Astro.props;
---

<article class="bg-white dark:bg-slate-800 rounded-lg shadow-md hover:shadow-lg dark:shadow-slate-900 transition-all overflow-hidden">
  {image && (
    <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover hover:scale-105 transition-transform" />
    </div>
  )}

  <div class="p-6">
    {/* Category Badge */}
    <div class="mb-3">
      <span class="inline-block px-3 py-1 text-sm font-semibold text-blue-600 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/30 rounded-full">
        {category}
      </span>
    </div>

    {/* Title */}
    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2 hover:text-blue-600 dark:hover:text-blue-400 transition">
      <a href={href}>{title}</a>
    </h3>

    {/* Description */}
    <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 line-clamp-2">
      {description}
    </p>

    {/* Meta Info */}
    <div class="flex items-center justify-between text-xs text-gray-500 dark:text-gray-500 border-t border-gray-200 dark:border-slate-700 pt-4">
      <div class="flex items-center space-x-3">
        <span>{author}</span>
        <span>•</span>
        <time datetime={new Date(date).toISOString()}>{new Date(date).toLocaleDateString()}</time>
        {readTime && (
          <>
            <span>•</span>
            <span>{readTime}</span>
          </>
        )}
      </div>
      <a href={href} class="text-blue-600 dark:text-blue-400 font-semibold hover:underline">
        Read →
      </a>
    </div>
  </div>
</article>
