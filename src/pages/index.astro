---
import PageLayout from '../layouts/PageLayout.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/shared/Footer.astro';
import { SITE_NAME, SITE_DESCRIPTION } from '../constants/site';

const title = `${SITE_NAME} - Home`;
---

<PageLayout title={title} description={SITE_DESCRIPTION}>
  <Header />

  {/* Hero Section */}
  <section class="py-20 text-center">
    <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6">
      Welcome to <span class="bg-gradient-to-r from-blue-600 to-blue-400 bg-clip-text text-transparent">Blog Me</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-8 max-w-2xl mx-auto">
      A modern, minimalist blog platform built with Astro. Fast, beautiful, and ready to share your ideas with the world.
    </p>
    <div class="flex gap-4 justify-center">
      <a href="/blog" class="px-8 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition">
        Read Articles →
      </a>
      <a href="/about" class="px-8 py-3 bg-gray-200 dark:bg-slate-700 text-gray-900 dark:text-white rounded-lg font-semibold hover:bg-gray-300 dark:hover:bg-slate-600 transition">
        Learn More
      </a>
    </div>
  </section>

  {/* Features Section */}
  <section class="py-16 grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="p-6 bg-gray-50 dark:bg-slate-800 rounded-lg">
      <div class="text-4xl mb-4">⚡</div>
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Lightning Fast</h3>
      <p class="text-gray-600 dark:text-gray-400">Static site generation for optimal performance</p>
    </div>
    <div class="p-6 bg-gray-50 dark:bg-slate-800 rounded-lg">
      <div class="text-4xl mb-4">🎨</div>
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Beautiful Design</h3>
      <p class="text-gray-600 dark:text-gray-400">Clean, modern interface with dark mode support</p>
    </div>
    <div class="p-6 bg-gray-50 dark:bg-slate-800 rounded-lg">
      <div class="text-4xl mb-4">📱</div>
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Responsive</h3>
      <p class="text-gray-600 dark:text-gray-400">Perfect on mobile, tablet, and desktop devices</p>
    </div>
  </section>

  {/* Call to Action */}
  <section class="py-16 text-center bg-gradient-to-r from-blue-50 dark:from-slate-800/50 to-blue-50/50 dark:to-slate-800/50 rounded-lg">
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Ready to Get Started?</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-6">Explore articles, projects, and more.</p>
    <a href="/blog" class="inline-block px-8 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition">
      Browse Blog →
    </a>
  </section>

  <Footer />
</PageLayout>
